    { "src": "/zubair", "dest": "/zubair.js" },
    { "src": "/meer", "dest": "/meer.js" },
    { "src": "/Sana", "dest": "/Sana.js" },
    { "src": "/Shabeer1", "dest": "/Shabeer1.js" },
    { "src": "/Shabeer2", "dest": "/Shabeer2.js" },
    { "src": "/Sanaulah", "dest": "/Sanaulah.js" },
    { "src": "/faisal", "dest": "/faisal.js" }
  ]
}
